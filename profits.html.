<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Profit Wall — Balloutt Trades</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <main class="wrap">
    <h1>📊 Profit Wall</h1>
    <p style="color:#b6a7d6;margin-bottom:20px;">Real results. Real screenshots.</p>
    <div class="profit-grid" id="profitGrid"></div>
    <div style="margin-top:30px;">
      <a href="index.html" class="link" style="display:inline-block;">← Back</a>
    </div>
  </main>
  <script>
    fetch('config.json')
      .then(r => r.json())
      .then(data => {
        const container = document.getElementById('profitGrid');
        data.profits.forEach(p => {
          const card = document.createElement('div');
          card.className = 'profit-card';
          card.innerHTML = `
            <img src="${p.image}" alt="${p.label}" />
            <div class="profit-label">${p.label}</div>
            <div class="profit-sub">${p.sub}</div>
          `;
          container.appendChild(card);
        });
      });
  </script>
</body>
</html>
